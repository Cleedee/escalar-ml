{
  "name": "escalar-ml",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.16.2",
    "@react-navigation/core": "^7.17.5",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.34",
    "expo-clipboard": "~8.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web && cp web/service-worker.js dist/service-worker.js && if [ \"$PUBLIC_URL\" != \"\" ]; then cd dist && find . -name '*.html' -exec sed -i 's|\"/_expo/|\"'\"$PUBLIC_URL\"'_expo/|g; s|\"/favicon.ico|\"'\"$PUBLIC_URL\"'favicon.ico|g' {} +; fi"
  },
  "private": true
}
